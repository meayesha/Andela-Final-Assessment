# =============================================================================
# Copy to repo root as `.env` (same folder as this file):
#   cp .env.example .env
# The FastAPI app loads REPO_ROOT/.env automatically.
# For local Next dev, also copy NEXT_PUBLIC_* into frontend/.env.local if needed.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenRouter (required for the LLM) — server-side only on the Python API host
# Never prefix secrets with NEXT_PUBLIC_ (that would expose them in the browser)
#
# Get a key: https://openrouter.ai/keys
# Model list: https://openrouter.ai/models
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
# OpenRouter model id, e.g. openai/gpt-4o-mini, anthropic/claude-3.5-haiku, google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini
# OpenAI-compatible base URL (change only if you use a proxy)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: OpenRouter rankings / attribution (https://openrouter.ai/docs/app-attribution)
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Todo MCP Chat

# -----------------------------------------------------------------------------
# Clerk (optional — when set, API requires Bearer session JWT; todos scoped per user)
# Frontend (Vercel): also set NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY in the same root .env
# (next.config loads ../.env). Docker static bundle uses docker-hf/ without Clerk UI.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWT verification: Clerk Dashboard → JWT templates → Session token → JWKS URL / Issuer
CLERK_JWKS_URL=
CLERK_ISSUER=

# -----------------------------------------------------------------------------
# Python API (FastAPI + MCP) — optional; defaults under backend/data/
# Leave blank or omit to use defaults (empty `KEY=` is treated as unset).
# -----------------------------------------------------------------------------
DATA_DIR=
TODO_DB_PATH=
AGENT_DB_PATH=

# Browser origins allowed to call the API (comma-separated), e.g.
# https://your-app.vercel.app,http://localhost:3000
# Leave empty to use built-in local dev defaults (localhost / 127.0.0.1 on 3000–3001, plus
# http(s)://192.168.*.*:port and 10.*.*.*:port for Next.js “Network” URLs on your LAN).
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Next.js / Vercel (frontend)
# -----------------------------------------------------------------------------
# Public base URL of your deployed Python API (no trailing slash required).
# Local Next dev: http://127.0.0.1:8000
# Vercel: set this in Vercel → Project → Settings → Environment Variables
# (Production + Preview) to your API’s public HTTPS origin.
# Leave empty only when the UI is served from the same origin as the API
# (e.g. single Docker container or uvicorn + backend/static).
NEXT_PUBLIC_API_URL=

# =============================================================================
# Vercel checklist (this repo: deploy the frontend from frontend/)
# =============================================================================
# 1. Deploy: connect the repo, set Root Directory to "frontend", framework Next.js.
# 2. Vercel env: set NEXT_PUBLIC_API_URL to your Python API’s public URL.
# 3. Do NOT put OPENROUTER_API_KEY in Vercel (this project keeps LLM keys on the Python API).
# 4. On your Python host set OPENROUTER_API_KEY, OPENROUTER_MODEL, and CORS_ORIGINS (*.vercel.app).
# 5. SQLite on ephemeral serverless disks resets unless the host gives a volume.
